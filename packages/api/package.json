{
  "name": "@cc-community/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "lint": "echo ok"
  },
  "dependencies": {
    "@cc-community/shared": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.7.0",
    "@prisma/client": "^6.1.0",
    "jsonwebtoken": "^9.0.0",
    "octokit": "^4.1.0",
    "stripe": "^17.3.0",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
